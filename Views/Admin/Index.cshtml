@using System.Globalization
@using sumile.Models
@using sumile.Services
@inject ShiftStatusDisplayService ShiftDisplay

@{
    ViewData["Title"] = "シフト一覧(管理者用)";

    var workloads = (ViewBag.Workloads as IEnumerable<DailyWorkload>)?.ToList()
                    ?? new List<DailyWorkload>();
    var recruitmentPeriods = ViewBag.RecruitmentPeriods as List<RecruitmentPeriod> ?? new List<RecruitmentPeriod>();
    int? selectedPeriodId = ViewBag.SelectedPeriodId as int?;
    var users = (ViewBag.Users as IEnumerable<dynamic> ?? new List<dynamic>()).OrderBy(u => u.CustomId);
    var shiftDays = ViewBag.Dates as List<ShiftDay> ?? new List<ShiftDay>();
    var submissions = ViewBag.Submissions as IEnumerable<ShiftSubmission> ?? new List<ShiftSubmission>();
    var workloadCells = ViewBag.WorkloadCells as List<ShiftTableWorkloadCell> ?? new List<ShiftTableWorkloadCell>();
    var shiftColumns = ViewBag.ShiftColumns as List<ShiftTableColumn> ?? new List<ShiftTableColumn>();
    var diffKeys = ViewBag.DiffKeys as HashSet<string> ?? new HashSet<string>();
    var totalAcceptedList = ViewBag.TotalAcceptedList as List<int> ?? new List<int>();
    var keyHolderAcceptedList = ViewBag.KeyHolderAcceptedList as List<int> ?? new List<int>();
    var requiredWorkersList = ViewBag.RequiredWorkersList as List<int> ?? new List<int>();
    var remainingWorkersList = ViewBag.RemainingWorkersList as List<int> ?? new List<int>();
    var shiftPdfUrl = ViewBag.ShiftPdfUrl as string;
    DateTime? shiftPdfUpdatedAt = ViewBag.ShiftPdfUpdatedAt is DateTime pdfUpdatedAt
        ? pdfUpdatedAt
        : null;
}

<h2>@ViewData["Title"]</h2>

<div class="mb-3">
    <a href="@Url.Action("SetRecruitmentPeriod", "Admin")" class="btn btn-primary">募集期間設定</a>
    <a href="@Url.Action("EditShifts", "Admin")" class="btn btn-secondary">シフト編集</a>
    <a href="@Url.Action("ShiftEditLogs", "Admin")" class="btn btn-info">編集履歴</a>

    <form asp-action="AutoAssignShifts" asp-controller="Admin" method="post" style="display:inline;">
        <input type="hidden" name="periodId" value="@selectedPeriodId" />
        <button type="submit" class="btn btn-warning" onclick="return confirm('この期間のシフトを自動割り当てしますか？');">
            シフト自動割り当て
        </button>
    </form>

    <a href="@Url.Action("EditDailyWorkload", "Admin")" class="btn btn-success">枚数編集</a>

    @if (selectedPeriodId != null)
    {
        <form asp-action="RegeneratePdf" asp-controller="Admin" method="post" style="display:inline;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="periodId" value="@selectedPeriodId" />
            <button type="submit" class="btn btn-outline-dark">この期間のPDFを今すぐ再出力</button>
        </form>
    }
</div>

<div class="mb-3">
    <label for="periodSelect">表示期間：</label>
    <select id="periodSelect" class="form-select" style="width:auto; display:inline;">
        @foreach (var rp in recruitmentPeriods)
        {
            <option value="@rp.Id" selected="@(rp.Id == selectedPeriodId)">
                @rp.StartDate.ToString("yyyy/MM/dd") ～ @rp.EndDate.ToString("yyyy/MM/dd")
            </option>
        }
    </select>

    @if (selectedPeriodId != null)
    {
        var selectedPeriod = recruitmentPeriods.FirstOrDefault(p => p.Id == selectedPeriodId);
        if (selectedPeriod != null)
        {
            <form asp-action="ToggleSubmissionStatus" asp-controller="Admin" method="post" style="display:inline;">
                <input type="hidden" name="id" value="@selectedPeriod.Id" />
                <button type="submit" class="btn btn-outline-warning ms-2">
                    @(selectedPeriod.IsOpen ? "締切にする" : "募集中に戻す")
                </button>
            </form>
        }
    }
</div>

<div class="admin-pdf-preview mb-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
        <div>
            <h3 class="h5 mb-1">最新PDF</h3>
            @if (shiftPdfUpdatedAt.HasValue)
            {
                <div class="text-muted small">更新: @shiftPdfUpdatedAt.Value.ToString("yyyy/MM/dd HH:mm")</div>
            }
        </div>

        @if (!string.IsNullOrEmpty(shiftPdfUrl))
        {
            <a href="@shiftPdfUrl" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm">別タブで開く</a>
        }
    </div>

    @if (!string.IsNullOrEmpty(shiftPdfUrl))
    {
        <object data="@shiftPdfUrl" type="application/pdf" class="admin-pdf-frame">
            <div class="text-muted small">
                PDFを表示できませんでした。<a href="@shiftPdfUrl" target="_blank" rel="noopener">別タブで開く</a>
            </div>
        </object>
    }
    else
    {
        <div class="admin-pdf-empty text-muted">
            この期間のPDFはまだ出力されていません。
        </div>
    }
</div>

<script>
    document.getElementById('periodSelect')?.addEventListener('change', function () {
        location.href = '@Url.Action("Index", "Admin")?periodId=' + this.value;
    });
</script>

<style>
    .current-user-row { background-color: #f3e8ff; }
    .shift-none { color: gray; }
    .shift-accepted { color: black; }
    .shift-want { color: orange; }
    .shift-keyholder { color: red; }
    .highlight-cell { background-color: #fff3cd; }
</style>

<div class="text-muted small mb-2">
    表上段の数値は必要枚数です。下段の必要人数・残りは人数で表示しています。
</div>

<div class="shift-table-fit">
<table class="table table-bordered text-center">
    <thead>
        <tr>
            <th rowspan="4">ユーザー</th>
            <th rowspan="4">鍵</th>
            @foreach (var day in shiftDays)
            {
                <th colspan="2">@day.Date.ToString("M/d")</th>
            }
        </tr>
        <tr>
            @foreach (var day in shiftDays)
            {
                <th colspan="2">@day.Date.ToString("ddd", new CultureInfo("ja-JP"))</th>
            }
        </tr>
        <tr>
            @foreach (var _ in shiftDays)
            {
                <th>上</th>
                <th>敷</th>
            }
        </tr>
        <tr>
            @foreach (var cell in workloadCells)
            {
                <td colspan="@cell.Colspan">@cell.RequiredCount</td>
            }
        </tr>
    </thead>

    <tbody>
        @foreach (var user in users)
        {
            bool isCurrentUser =
                ViewBag.CurrentUserCustomId != null &&
                user.CustomId.ToString() == ViewBag.CurrentUserCustomId;

            <tr class="@(isCurrentUser ? "current-user-row" : "")">
                <td>@user.Name</td>
                <td>@(user.UserShiftRole == UserShiftRole.KeyHolder ? "★" : "")</td>

                @foreach (var column in shiftColumns)
                {
                    var submission = submissions.FirstOrDefault(s =>
                        s.UserId == user.Id &&
                        s.ShiftDayId == column.ShiftDayId &&
                        s.ShiftType == column.ShiftType);

                    var key = $"{user.Id}_{column.ShiftDayId}_{(int)column.ShiftType}";
                    var display = ShiftDisplay.GetDisplay(submission?.ShiftStatus);

                    if (submission?.UserShiftRole == UserShiftRole.KeyHolder && display.Symbol == "〇")
                        display.CssClass += " shift-keyholder";

                    <td class="@(diffKeys.Contains(key) ? "highlight-cell" : "") @display.CssClass">
                        @display.Symbol
                    </td>
                }
            </tr>
        }
    </tbody>

    <tfoot>
        <tr>
            <td colspan="2">必要人数</td>
            @foreach (var v in requiredWorkersList)
            {
                <td>@v</td>
            }
        </tr>

        <tr>
            <td colspan="2">〇</td>
            @foreach (var v in totalAcceptedList)
            {
                <td>@v</td>
            }
        </tr>
        <tr>
            <td colspan="2">赤丸</td>
            @foreach (var v in keyHolderAcceptedList)
            {
                <td>@v</td>
            }
        </tr>
        <tr>
            <td colspan="2">残り</td>
            @foreach (var v in remainingWorkersList)
            {
                <td class="@(v < 0 ? "text-danger fw-bold" : "")">@v</td>
            }
        </tr>
    </tfoot>
</table>
</div>
