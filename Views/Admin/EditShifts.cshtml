@using sumile.Models
@using sumile.Services
@using System.Globalization

@{
    ViewData["Title"] = "シフト編集";

    var users = ViewBag.Users as IEnumerable<dynamic> ?? new List<dynamic>();
    var shiftDays = ViewBag.Dates as List<ShiftDay> ?? new List<ShiftDay>();
    var submissions = ViewBag.Submissions as List<ShiftSubmission> ?? new List<ShiftSubmission>();
    var backups = ViewBag.Backups as List<SubmitBackup> ?? new List<SubmitBackup>();

    var workloads = ViewBag.Workloads as List<DailyWorkload> ?? new List<DailyWorkload>();
    var workloadCells = ViewBag.WorkloadCells as List<ShiftTableWorkloadCell> ?? new List<ShiftTableWorkloadCell>();
    var shiftColumns = ViewBag.ShiftColumns as List<ShiftTableColumn> ?? new List<ShiftTableColumn>();
    var totalAccepted = ViewBag.TotalAcceptedList as List<int> ?? new List<int>();
    var keyAccepted = ViewBag.KeyHolderAcceptedList as List<int> ?? new List<int>();
    var requiredWorkers = ViewBag.RequiredWorkersList as List<int> ?? new List<int>();
    var remaining = ViewBag.RemainingWorkersList as List<int> ?? new List<int>();
    var hasInitialConfirmation = ViewBag.HasInitialConfirmation as bool? ?? false;

    var recruitmentPeriods = ViewBag.RecruitmentPeriods as List<RecruitmentPeriod> ?? new List<RecruitmentPeriod>();
    int? selectedPeriodId = ViewBag.SelectedPeriodId as int?;
}

<h2>@ViewData["Title"]</h2>

<form method="get" asp-action="EditShifts">
    <select name="periodId" class="form-select w-auto d-inline">
        @foreach (var p in recruitmentPeriods)
        {
            <option value="@p.Id" selected="@(p.Id == selectedPeriodId)">
                @p.StartDate.ToString("yyyy/MM/dd") ～ @p.EndDate.ToString("MM/dd")
            </option>
        }
    </select>
    <button type="submit" class="btn btn-secondary ms-2">表示</button>
</form>

<hr />

@Html.AntiForgeryToken()

<div class="text-muted small mb-2">
    表上段の数値は必要枚数です。下段の必要人数・残りは人数で表示しています。
    黄色のセルは、締切時に保存した初期提出状態から変更されています。
    @if (hasInitialConfirmation)
    {
        <text>初回確定後の変更はそのまま保存できます。必要なときだけ変更理由を残してください。</text>
    }
    else
    {
        <text>最初の保存は「初回確定」として扱われ、その内容が Shift/Index に反映されます。</text>
    }
</div>

<div class="shift-table-fit">
<table class="table table-bordered table-sm text-center align-middle">
    <thead>
        <tr>
            <th rowspan="4">ID</th>
            <th rowspan="4">名前</th>
            <th rowspan="4">通過率</th>
            @foreach (var day in shiftDays)
            {
                <th colspan="2">@day.Date.ToString("M/d")</th>
            }
        </tr>
        <tr>
            @foreach (var day in shiftDays)
            {
                <th colspan="2">@day.Date.ToString("ddd", new CultureInfo("ja-JP"))</th>
            }
        </tr>
        <tr>
            @foreach (var day in shiftDays)
            {
                <th>上</th>
                <th>敷</th>
            }
        </tr>
        <tr>
            @foreach (var cell in workloadCells)
            {
                <td colspan="@cell.Colspan">@cell.RequiredCount</td>
            }
        </tr>
    </thead>

    <tbody>
        @foreach (var user in users)
        {
            var userId = (string)user.Id;
            var userShiftStates = shiftColumns
                .Select(column => submissions.FirstOrDefault(s =>
                    s.UserId == userId &&
                    s.ShiftDayId == column.ShiftDayId &&
                    s.ShiftType == column.ShiftType)?.ShiftStatus ?? ShiftState.None)
                .ToList();
            var submittedCount = userShiftStates.Count(state => state != ShiftState.None);
            var acceptedCount = userShiftStates.Count(state => state == ShiftState.Accepted || state == ShiftState.KeyHolder);
            var passRateText = submittedCount == 0
                ? "-"
                : $"{acceptedCount}/{submittedCount} ({Math.Round(acceptedCount * 100.0 / submittedCount):0}%)";

            <tr>
                <td>@user.CustomId</td>
                <td>
                    @user.Name
                    @if (user.UserShiftRole == UserShiftRole.KeyHolder)
                    {
                        <span class="text-warning ms-1">★</span>
                    }
                </td>
                <td class="shift-pass-rate text-nowrap small" data-user-rate="@userId">@passRateText</td>

                @foreach (var column in shiftColumns)
                {
                    var current = submissions.FirstOrDefault(s =>
                        s.UserId == userId &&
                        s.ShiftDayId == column.ShiftDayId &&
                        s.ShiftType == column.ShiftType);

                    var state = current?.ShiftStatus ?? ShiftState.None;

                    var backup = backups.FirstOrDefault(b =>
                        b.UserId == userId &&
                        b.ShiftDayId == column.ShiftDayId &&
                        b.ShiftType == column.ShiftType);

                    var initialState = backup?.ShiftStatus ?? ShiftState.None;
                    bool isDiff = initialState != state;

                    string display = ConvertStateToSymbol(state);
                    string cellTitle = $"初期: {ConvertStateToLabel(initialState)} / 編集前: {ConvertStateToLabel(state)} / 現在: {ConvertStateToLabel(state)}";

                    <td class="editable-cell @(isDiff ? "bg-warning" : "")"
                        data-user="@userId"
                        data-day="@column.Date.ToString("yyyy-MM-dd")"
                        data-type="@((int)column.ShiftType)"
                        data-state="@((int)state)"
                        data-initial-state="@((int)initialState)"
                        data-original-state="@((int)state)"
                        title="@cellTitle">
                        @display
                    </td>
                }
            </tr>
        }
    </tbody>

    <tfoot>
        <tr>
            <td colspan="3">必要人数</td>
            @for (int i = 0; i < requiredWorkers.Count; i++)
            {
                <td data-foot="required" data-idx="@i">@requiredWorkers[i]</td>
            }
        </tr>

        <tr>
            <td colspan="3">〇</td>
            @for (int i = 0; i < totalAccepted.Count; i++)
            {
                <td data-foot="accepted" data-idx="@i">@totalAccepted[i]</td>
            }
        </tr>
        <tr>
            <td colspan="3">🔴</td>
            @for (int i = 0; i < keyAccepted.Count; i++)
            {
                <td data-foot="key" data-idx="@i">@keyAccepted[i]</td>
            }
        </tr>
        <tr>
            <td colspan="3">残り</td>
            @for (int i = 0; i < remaining.Count; i++)
            {
                <td data-foot="remain" data-idx="@i" class="@(remaining[i] < 0 ? "text-danger fw-bold" : "")">@remaining[i]</td>
            }
        </tr>
    </tfoot>
</table>
</div>

@if (hasInitialConfirmation)
{
    <div class="mt-3" style="max-width: 720px;">
        <label for="changeReason" class="form-label">変更理由</label>
        <textarea id="changeReason" class="form-control" rows="3" placeholder="必要なときだけ入力してください"></textarea>
        <div class="form-text">従業員同士の都合調整なら空でも大丈夫です。特別業務など理由を残したい変更のときに使ってください。</div>
    </div>
}

<button id="saveBtn" class="btn btn-primary mt-3">@(hasInitialConfirmation ? "変更を保存" : "初回確定")</button>
<a asp-controller="Admin" asp-action="Index" asp-route-periodId="@selectedPeriodId"
   class="btn btn-secondary mt-3 ms-2">保存せずに戻る</a>

@functions {
    string ConvertStateToSymbol(ShiftState state)
    {
        return state switch
        {
            ShiftState.Accepted => "〇",
            ShiftState.NotAccepted => "",
            ShiftState.WantToGiveAway => "△",
            ShiftState.KeyHolder => "🔴",
            _ => "×"
        };
    }

    string ConvertStateToLabel(ShiftState state)
    {
        return state switch
        {
            ShiftState.Accepted => "〇",
            ShiftState.NotAccepted => "空白",
            ShiftState.WantToGiveAway => "△",
            ShiftState.KeyHolder => "赤丸",
            _ => "×"
        };
    }
}

@section Scripts {
<script>
    const cells = document.querySelectorAll(".editable-cell");
    const fixedColumnCount = 3;
    const passRateTds = [...document.querySelectorAll(".shift-pass-rate")];
    const acceptedTds = [...document.querySelectorAll('[data-foot="accepted"]')];
    const keyTds = [...document.querySelectorAll('[data-foot="key"]')];
    const requiredTds = [...document.querySelectorAll('[data-foot="required"]')];
    const remainTds = [...document.querySelectorAll('[data-foot="remain"]')];
    const requestVerificationToken =
        document.querySelector('input[name="__RequestVerificationToken"]')?.value;

    const requiredByCol = requiredTds.map(td => parseInt(td.innerText || "0", 10));

    function symbolFromState(state) {
        return state == 1 ? "〇" :
            state == 2 ? "" :
            state == 3 ? "△" :
            state == 4 ? "🔴" : "×";
    }

    function labelFromState(state) {
        return state == 1 ? "〇" :
            state == 2 ? "空白" :
            state == 3 ? "△" :
            state == 4 ? "赤丸" : "×";
    }

    function isSubmittedState(state) {
        return state !== 0;
    }

    function isAcceptedState(state) {
        return state === 1 || state === 4;
    }

    function formatPassRate(accepted, submitted) {
        if (submitted === 0) return "-";

        return `${accepted}/${submitted} (${Math.round(accepted * 100 / submitted)}%)`;
    }

    function recalcPassRates() {
        passRateTds.forEach(td => {
            const rowCells = [...td.closest("tr").querySelectorAll(".editable-cell")];
            const submitted = rowCells.filter(cell => isSubmittedState(parseInt(cell.dataset.state || "0", 10))).length;
            const accepted = rowCells.filter(cell => isAcceptedState(parseInt(cell.dataset.state || "0", 10))).length;

            td.innerText = formatPassRate(accepted, submitted);
            td.classList.toggle("text-muted", submitted === 0);
        });
    }

    function updateCellMeta(cell) {
        const initial = parseInt(cell.dataset.initialState || "0", 10);
        const original = parseInt(cell.dataset.originalState || "0", 10);
        const current = parseInt(cell.dataset.state || "0", 10);

        cell.title = `初期: ${labelFromState(initial)} / 編集前: ${labelFromState(original)} / 現在: ${labelFromState(current)}`;
        cell.classList.toggle("bg-warning", initial !== current);
    }

    function render(cell, state) {
        cell.dataset.state = state;
        cell.innerText = symbolFromState(state);
        updateCellMeta(cell);
    }

    function nextLeft(state) {
        if (state == 1) return 2;
        if (state == 2) return 0;
        if (state == 0) return 1;
        return state;
    }


    function nextRight(state) {
        // 〇 → 🔴 → △ → 〇
        if (state == 1) return 4;
        if (state == 4) return 3;
        if (state == 3) return 1;
        return state;
    }

    function recalcFooter() {
        const accepted = new Array(acceptedTds.length).fill(0);
        const key = new Array(keyTds.length).fill(0);

        cells.forEach(cell => {
            const col = cell.cellIndex - fixedColumnCount;
            if (col < 0 || col >= accepted.length) return;

            const state = parseInt(cell.dataset.state);
            if (state === 1 || state === 4) accepted[col]++;
            if (state === 4) key[col]++;
        });

        acceptedTds.forEach((td, i) => td.innerText = accepted[i]);
        keyTds.forEach((td, i) => td.innerText = key[i]);
        remainTds.forEach((td, i) => {
            const diff = accepted[i] - requiredByCol[i];
            td.innerText = diff;
            td.classList.toggle("text-danger", diff < 0);
            td.classList.toggle("fw-bold", diff < 0);
        });
    }

    cells.forEach(cell => {
        updateCellMeta(cell);

        cell.addEventListener("click", () => {
            const s = parseInt(cell.dataset.state);
            render(cell, nextLeft(s));
            recalcFooter();
            recalcPassRates();
        });

        cell.addEventListener("contextmenu", e => {
            e.preventDefault();
            const s = parseInt(cell.dataset.state);
            if (s !== 2 && s !== 0) {
                render(cell, nextRight(s));
                recalcFooter();
                recalcPassRates();
            }
        });
    });

    recalcPassRates();

    document.getElementById("saveBtn").addEventListener("click", async () => {
        const updates = [];
        cells.forEach(cell => {
            const payload = {
                userId: cell.dataset.user,
                date: cell.dataset.day,
                shiftType: parseInt(cell.dataset.type),
                shiftState: parseInt(cell.dataset.state),
                shiftStatus:
                    cell.dataset.state == 1 ? "〇" :
                    cell.dataset.state == 3 ? "△" :
                    cell.dataset.state == 4 ? "🔴" :
                    cell.dataset.state == 0 ? "×" : ""
            };

            updates.push(payload);
        });

        const reason = document.getElementById("changeReason")?.value?.trim() ?? "";

        const res = await fetch(`/Admin/UpdateShifts?periodId=@selectedPeriodId`, {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "RequestVerificationToken": requestVerificationToken ?? ""
            },
            body: JSON.stringify({
                shiftUpdates: updates,
                reason
            })
        });

        let result;
        try {
            result = await res.json();
        } catch {
            alert("保存に失敗しました。権限またはCSRFトークンを確認してください。");
            return;
        }

        if (result.success) {
            alert("保存しました");
            location.reload();
        } else {
            alert(result.error ?? "保存に失敗しました");
        }
    });
</script>
}
